# Exit Interview Agent — Environment Variables

# OpenAI API Key (required for agent LLM calls)
OPENAI_API_KEY=sk-your-openai-key-here

# Ollama fallback endpoint (optional, defaults to localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Voice Engine (optional — for voice interview modes)
# ---------------------------------------------------------------------------

# Whisper model for speech-to-text
# Options: tiny.en | base.en | small.en
# Smaller = faster, larger = more accurate
WHISPER_MODEL=base.en

# Kokoro voice for text-to-speech
# Options: af_heart | af_bella | af_sarah | am_adam | bm_george | bf_emma
KOKORO_VOICE=af_heart
